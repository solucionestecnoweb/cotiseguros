<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="res_partner_inh" model="ir.ui.view">
            <field name="name">res.partner.inh</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
               
                <xpath expr="//field[@name='category_id']" position="after">
                    <field name="policy_number"/>
                    <field name="type_partner_id"/>
                    <field name="emission_date"/>
                    <field name="due_date"/>
                </xpath>
                <xpath expr="//field[@name='vat']" position="after">
                    <field name="age"/>
                    <field name="gender"/>
                    <field name="modify_individual_label_policyholder"/>
                    <field name="modify_contact_file_beneficiary"/>
                    <field name="rif_ci"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>